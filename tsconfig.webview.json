{
  "compilerOptions": {
    "module": "ES2020",
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "outDir": "dist/webview",
    "rootDir": "webview-ui",
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["webview-ui/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
